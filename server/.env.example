# Game server
PORT=2567

# Auth server
AUTH_PORT=3001
JWT_SECRET=change-me-in-production

# CORS — comma-separated list of allowed origins (defaults to localhost:3000 in dev)
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://pixelrealm:pixelrealm_dev@localhost:5432/pixelrealm

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# SIWE (Sign-In with Ethereum) — wallet linking challenge
# SIWE_DOMAIN should match the domain players access the game from (no port, no scheme).
SIWE_DOMAIN=localhost
# SIWE_URI should be the auth server URI used in EIP-4361 challenges.
SIWE_URI=http://localhost:3001

# Anthropic (Claude API for LLM quest generation)
ANTHROPIC_API_KEY=sk-ant-...
# Max quest generations per minute (global); default 10
QUEST_GEN_RATE_LIMIT=10
# Hard cap on total tokens (prompt + completion) per quest generation; alerts logged on overrun. Default 1200.
QUEST_TOKEN_BUDGET=1200
