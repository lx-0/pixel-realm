{
  "name": "pixelrealm-server",
  "version": "0.1.0",
  "private": true,
  "description": "PixelRealm Colyseus multiplayer game server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node-dev --transpile-only src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@colyseus/core": "^0.15.57",
    "@colyseus/schema": "^2.0.37",
    "@colyseus/ws-transport": "^0.15.3",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.18.2",
    "fastify": "^4.29.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.20.18",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
