{
  "name": "pixelrealm-server",
  "version": "0.1.0",
  "private": true,
  "description": "PixelRealm Colyseus multiplayer game server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/core": "^0.15.57",
    "@colyseus/schema": "^2.0.37",
    "@colyseus/ws-transport": "^0.15.3",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.11.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
