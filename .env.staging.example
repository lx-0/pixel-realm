# ──────────────────────────────────────────────────────────────────────────────
# PixelRealm — Staging Environment Variables
#
# Copy this file to .env.staging and fill in values before deploying staging.
# NEVER commit .env.staging to source control.
#
# Usage:
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up --build
# ──────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────

NODE_ENV=staging

# ── Server ports ──────────────────────────────────────────────────────────────

# Colyseus WebSocket + Express HTTP port
PORT=2567

# Fastify auth server port
AUTH_PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────

# REQUIRED — use a dedicated staging database, not production!
DATABASE_URL=postgresql://pixelrealm:CHANGE_ME@localhost:5432/pixelrealm_staging

POSTGRES_DB=pixelrealm_staging
POSTGRES_USER=pixelrealm
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────

# REQUIRED
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# ── Authentication ────────────────────────────────────────────────────────────

# REQUIRED — may differ from production; keep separate so staging tokens
# cannot be replayed against production.
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_STAGING

# ── CORS ──────────────────────────────────────────────────────────────────────

# Set to your staging client URL (no trailing slash).
ALLOWED_ORIGINS=http://localhost:8080

# ── Docker-compose port mapping ───────────────────────────────────────────────

# Staging client defaults to port 8080 to avoid clashing with production
# if both run on the same host.
GAME_PORT=2567
AUTH_PORT=3001
CLIENT_PORT=8080

# ── Client (Vite build) ───────────────────────────────────────────────────────

# WebSocket URL the browser client connects to (plain ws:// for staging).
# Update to wss:// if your staging environment terminates TLS upstream.
VITE_COLYSEUS_URL=ws://localhost:2567
