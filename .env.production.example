# ──────────────────────────────────────────────────────────────────────────────
# PixelRealm — Production Environment Variables
#
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to source control.
# Variables marked REQUIRED must be set or the server will refuse to start.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────

# Must be "production" in all deployed environments.
NODE_ENV=production

# ── Server ports ──────────────────────────────────────────────────────────────

# Colyseus WebSocket + Express HTTP port (game server)
# REQUIRED
PORT=2567

# Fastify auth server port
# REQUIRED
AUTH_PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────

# Full PostgreSQL connection string.
# REQUIRED — server exits immediately if this is missing in production.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://pixelrealm:CHANGE_ME@localhost:5432/pixelrealm

# Convenience vars used by docker-compose.prod.yml to build DATABASE_URL.
# Only needed when using the provided docker-compose setup.
POSTGRES_DB=pixelrealm
POSTGRES_USER=pixelrealm
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────

# Full Redis connection string.
# REQUIRED — server exits immediately if this is missing in production.
# Format: redis://:<password>@<host>:<port>
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Convenience var used by docker-compose.prod.yml.
REDIS_PASSWORD=CHANGE_ME

# ── Authentication ────────────────────────────────────────────────────────────

# Secret used to sign JWT access and refresh tokens.
# REQUIRED — use a random string of at least 32 characters.
# Generate one with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS.
# Set to your production client URL (no trailing slash).
# REQUIRED
ALLOWED_ORIGINS=https://yourdomain.com

# ── Docker-compose port mapping (optional) ────────────────────────────────────

# Host port that maps to the game server container port (default: 2567)
GAME_PORT=2567

# Host port that maps to the nginx client container port (default: 80)
CLIENT_PORT=80

# ── Client (Vite build) ───────────────────────────────────────────────────────

# WebSocket URL the browser client connects to.
# Must be the publicly reachable address of the game server.
VITE_COLYSEUS_URL=wss://yourdomain.com
