# Colyseus game server URL.
# Leave unset (or point to localhost) for local dev.
# In production, set to your deployed Colyseus server WebSocket URL.
VITE_COLYSEUS_URL=ws://localhost:2567

# Auth server URL (Fastify, runs separately from the Colyseus game server).
# Used by WalletPanel and any client code that calls JWT-protected auth endpoints.
VITE_AUTH_URL=http://localhost:3001

# WalletConnect v2 project ID — register at https://cloud.walletconnect.com
# If unset, WalletConnect connector is skipped (MetaMask + Coinbase still work).
VITE_WALLETCONNECT_PROJECT_ID=
