# Colyseus game server URL.
# Leave unset (or point to localhost) for local dev.
# In production, set to your deployed Colyseus server WebSocket URL.
VITE_COLYSEUS_URL=ws://localhost:2567

# NFT contract addresses on Base Sepolia (M14a–M14d).
# Leave unset to disable on-chain features (panels will not instantiate).
# Set these after deploying contracts via `forge script` in /contracts.
VITE_ITEMS_CONTRACT_ADDRESS=
VITE_LAND_CONTRACT_ADDRESS=
VITE_MARKETPLACE_CONTRACT_ADDRESS=
