# Base Sepolia RPC (e.g. from Alchemy/Infura or public endpoint)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key_here

# Deployer EOA private key (never commit the real key)
DEPLOYER_PRIVATE_KEY=0xdeadbeef...

# Role addresses
ADMIN_ADDRESS=0x...      # DEFAULT_ADMIN_ROLE holder
MINTER_ADDRESS=0x...     # MINTER_ROLE holder (server operator hot wallet)
UPGRADER_ADDRESS=0x...   # UPGRADER_ROLE holder (Gnosis Safe 3-of-5)
TREASURY_ADDRESS=0x...   # ERC-2981 royalty recipient

# IPFS metadata base URIs (set after Pinata upload)
ITEMS_BASE_URI=ipfs://QmYourItemsCID/{id}.json
LAND_BASE_URI=ipfs://QmYourLandCID/
