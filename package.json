{
  "name": "pixelrealm",
  "version": "0.6.0",
  "private": true,
  "description": "PixelRealm — browser-based pixelated MMORPG with LLM-generated content",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "cd server && vitest run",
    "lint": "eslint src/",
    "deploy": "butler push dist ${ITCH_GAME:-pixelforgestudios/pixelrealm}:html5 --userversion $npm_package_version",
    "deploy:fresh": "npm run build && npm run deploy"
  },
  "dependencies": {
    "colyseus.js": "^0.15.28",
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
