{
  "name": "pixelrealm",
  "version": "2.0.0",
  "private": true,
  "description": "PixelRealm — browser-based pixelated MMORPG with LLM-generated content",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "cd server && vitest run",
    "lint": "eslint src/",
    "deploy": "butler push dist ${ITCH_GAME:-pixelforgestudios/pixelrealm}:html5 --userversion $npm_package_version",
    "deploy:fresh": "npm run build && npm run deploy",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@wagmi/connectors": "^5.7.0",
    "@wagmi/core": "^2.16.0",
    "colyseus.js": "^0.15.28",
    "phaser": "^3.80.0",
    "sharp": "^0.34.5",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "canvas": "^3.2.2",
    "eslint": "^10.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
